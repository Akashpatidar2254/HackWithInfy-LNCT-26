solution: 
#include <iostream>
#include <vector>
#include <algorithm>
#include <climits>
using namespace std;

// Kadane's algorithm restricted to subarray [i, j]
int kadaneRange(const vector<int>& arr, int i, int j) {
    int maxSoFar = INT_MIN;
    int maxEndingHere = 0;
    for (int k = i; k <= j; k++) {
        maxEndingHere += arr[k];
        maxSoFar = max(maxSoFar, maxEndingHere);
        if (maxEndingHere < 0) maxEndingHere = 0;
    }
    return maxSoFar;
}

int main() {
    int N, K;
    cin >> N >> K;
    vector<int> arr(N);
    for (int i = 0; i < N; i++) cin >> arr[i];

    int base_ans = kadaneRange(arr, 0, N - 1);
    int total = INT_MIN;

    for (int i = 0; i < N - 1; i++) {
        for (int j = i + 1; j < N; j++) {
            while (K > 0) {
                int curr_ans = kadaneRange(arr, i, j);
                total = max(total, curr_ans);

                // Find smallest element in [i, j]
                auto min_iter = min_element(arr.begin() + i, arr.begin() + j + 1);
                int minIndex = distance(arr.begin(), min_iter);

                // Find largest element outside [i, j]
                int maxVal = INT_MIN;
                int maxIndex = -1;

                if (i > 0) {
                    auto outer1 = max_element(arr.begin(), arr.begin() + i);
                    if (*outer1 > maxVal) {
                        maxVal = *outer1;
                        maxIndex = distance(arr.begin(), outer1);
                    }
                }
                if (j + 1 < arr.size()) {
                    auto outer2 = max_element(arr.begin() + j + 1, arr.end());
                    if (*outer2 > maxVal) {
                        maxVal = *outer2;
                        maxIndex = distance(arr.begin(), outer2);
                    }
                }

                if (minIndex != -1 && maxIndex != -1) {
                    swap(arr[minIndex], arr[maxIndex]);
                }

                K--;
            }
        }
    }

    int m = max(total, base_ans);
    cout << m << endl;
    return 0;
}
