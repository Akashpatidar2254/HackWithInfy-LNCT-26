#include <iostream>
#include <unordered_map>
#include <vector>
#include <algorithm>
#include <climits>
using namespace std;

int main() {
    int n;
    cin>>n;
    vector<int>L(n);
    for(int i=0;i<n;i++){
        cin>>L[i];
    }
    
    int result=INT_MAX;
    for(int i=0;i<n-1;i++){
        for(int j=i+1;j<n;j++){
            int eff=abs(L[i]-L[j]);
            if(eff==0) continue;
            if(eff%2==0){
                result=min(result,eff);
            }
        }
    }
    
    if(result==INT_MAX) cout<<-1;
    cout<<result;
	return 0;
}
	    
	
